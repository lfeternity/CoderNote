# Reference template only. Spring Boot does not load this file automatically.
# Export these variables in your shell or configure them in your IDE / process manager.

SERVER_PORT=8080
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=Lax
MYBATIS_LOG_IMPL=org.apache.ibatis.logging.nologging.NoLoggingImpl

DB_URL=jdbc:mysql://127.0.0.1:3306/coder_note?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=2000ms
REDIS_CONNECT_TIMEOUT=2000ms
REDIS_POOL_MAX_ACTIVE=32
REDIS_POOL_MAX_IDLE=16
REDIS_POOL_MIN_IDLE=4
REDIS_POOL_MAX_WAIT=2000ms
SESSION_TIMEOUT=30m
REDIS_SESSION_NAMESPACE=codernote:session
APP_CACHE_STATISTICS_OVERVIEW_TTL_SECONDS=30
APP_CACHE_STATISTICS_OVERVIEW_LOCK_SECONDS=3
APP_CACHE_STATISTICS_OVERVIEW_MAX_PAYLOAD_BYTES=131072
APP_CACHE_SEARCH_TTL_SECONDS=20
APP_CACHE_SEARCH_LOCK_SECONDS=3
APP_CACHE_SEARCH_MAX_PAGE_SIZE=50
APP_CACHE_SEARCH_MAX_PAGE_NO=1000
APP_CACHE_SEARCH_MAX_CACHED_PAGE_NO=10
APP_CACHE_SEARCH_MAX_KEYWORD_LENGTH=64
APP_CACHE_SEARCH_MAX_PAYLOAD_BYTES=262144
APP_SCHEDULE_REVIEW_DAILY_CRON="0 0 0 * * ?"
APP_SCHEDULE_REVIEW_DAILY_LOCK_SECONDS=3600

APP_UPLOAD_BASE_DIR=uploads
APP_AVATAR_BASE_DIR=uploads/avatar
OAUTH_FRONTEND_BASE_URL=http://127.0.0.1:5173
KNIFE4J_ENABLE=false
APP_SECURITY_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
APP_SECURITY_CSRF_ENABLED=true
APP_SECURITY_CSRF_COOKIE_SECURE=false
APP_SECURITY_CSRF_COOKIE_SAME_SITE=Lax
APP_AI_ALLOW_RUNTIME_MODEL_CONFIG=false
APP_AI_RUNTIME_ALLOWED_HOSTS=api.openai.com,dashscope.aliyuncs.com,api.moonshot.cn,api.deepseek.com,generativelanguage.googleapis.com,api.anthropic.com

QWEN_API_KEY=
QWEN_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_MODEL=qwen-plus

KIMI_API_KEY=
KIMI_ENDPOINT=https://api.moonshot.cn/v1/chat/completions
KIMI_MODEL=moonshot-v1-8k

OPENAI_API_KEY=
OPENAI_ENDPOINT=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-5.2
